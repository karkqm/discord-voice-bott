DISCORD_BOT_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# LLM Settings
LLM_MODEL=gemini-2.5-flash-lite
LLM_MAX_TOKENS=150
LLM_TEMPERATURE=0.9

# Voice Settings
# STT_BACKEND: "onnx" (onnx-asr + DirectML/AMD) or "realtime" (RealtimeSTT + CUDA/NVIDIA)
STT_BACKEND=realtime
STT_MODEL=base
STT_LANGUAGE=ru
# TTS: Silero v4 (local, fast). Voices: xenia, aidar, baya, kseniya, eugene
TTS_ENGINE=silero
TTS_VOICE=xenia

# Web Search (Brave Search API — free 2000 req/mo, get key at https://brave.com/search/api/)
BRAVE_API_KEY=

# Screen Capture
SCREEN_CAPTURE_INTERVAL=5
SCREEN_CAPTURE_ENABLED=true

# Bot Personality
BOT_NAME=Алекс

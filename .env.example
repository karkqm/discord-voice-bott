DISCORD_BOT_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# LLM Settings
LLM_MODEL=gemini-2.5-flash-lite
LLM_MAX_TOKENS=150
LLM_TEMPERATURE=0.9

# Voice Settings
STT_MODEL=base
STT_LANGUAGE=ru
TTS_ENGINE=edge
TTS_VOICE=ru-RU-DmitryNeural

# Screen Capture
SCREEN_CAPTURE_INTERVAL=5
SCREEN_CAPTURE_ENABLED=true

# Bot Personality
BOT_NAME=Алекс
